# =============================================================================
# MovieLust — copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored; never commit real keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Required (used by the app)
# -----------------------------------------------------------------------------
# Where to find: Supabase Dashboard → your project → Project Settings → API
#
# Project URL — under "Project URL"
#   Example: https://abcdefghijklmnop.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# anon / public key — under "Project API keys" → "anon" / "public"
#   Long JWT starting with eyJ... — safe to expose in the browser with RLS.
#   Do NOT use the "service_role" secret here (that bypasses RLS).
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Site URL for magic-link redirects (local dev and production).
# Example local: http://localhost:4000  (match `npm run dev` port)
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Optional (not required for this repo today)
# -----------------------------------------------------------------------------
# Service role — only if you later add server-only admin scripts.
# Never prefix with NEXT_PUBLIC_ — never send to the browser.
# SUPABASE_SERVICE_ROLE_KEY=
